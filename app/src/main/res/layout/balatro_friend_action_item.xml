<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/balatro_friend_action_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_text_or_item_balatro"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/tenTextView"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:fontFamily="@font/m6x11plus"
        android:text="Tiêu đề"
        android:textColor="#F4EFEF"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/balatroButtonAction"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tienTextView"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:fontFamily="@font/m6x11plus"
        android:text="Nội dung"
        android:textColor="#F4EFEF"
        android:textSize="17sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/balatroButtonAction"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tenTextView"
        app:layout_constraintVertical_bias="0.0" />

    <com.gamebai.tienlenmiennam.uisanhcho.BalatroButton
        android:id="@+id/balatroButtonAction"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="chấp nhận"
        app:colorFont="@color/white"
        app:colorNormal="@color/balatro_green"
        app:fontSize="17dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>