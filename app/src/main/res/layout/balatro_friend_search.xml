<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/balatro_friend_search"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_text_or_item_balatro"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <com.gamebai.tienlenmiennam.uisanhcho.BalatroButton
        android:id="@+id/balatroButtonTimKiem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="tìm kiếm"
        app:colorFont="@color/white"
        app:colorNormal="@color/balatro_blue"
        app:fontSize="17dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.gamebai.tienlenmiennam.uisanhcho.BalatroEditText
        android:id="@+id/balatroEditTextSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:hint="Tên người chơi"
        android:maxLength="12"
        android:textColor="@color/white"
        app:fontSize="17dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/balatroButtonTimKiem"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>