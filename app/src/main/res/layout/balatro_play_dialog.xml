<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/balatro_play"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dialog_balatro"
    android:padding="50dp">

    <com.gamebai.tienlenmiennam.uisanhcho.BalatroEditText
        android:id="@+id/balatroEditTextRoomCode"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:gravity="center"
        android:hint="Mã phòng"
        android:inputType="number"
        android:maxLength="4"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textColorHint="#67FFFFFF"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/balatroEditTextRoomCode"
        app:layout_constraintVertical_bias="0.0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.gamebai.tienlenmiennam.uisanhcho.BalatroButton
                android:id="@+id/balatroButtonPlay"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="Chơi ngay"
                app:colorFont="@color/white"
                app:colorNormal="@color/balatro_red"
                app:fontSize="24sp" />

            <com.gamebai.tienlenmiennam.uisanhcho.BalatroButton
                android:id="@+id/balatroButtonCreateRoom"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="0dp"
                android:text="Tạo phòng mới"
                app:colorFont="@color/white"
                app:colorNormal="@color/balatro_green"
                app:fontSize="24sp" />

            <com.gamebai.tienlenmiennam.uisanhcho.BalatroButton
                android:id="@+id/balatroButtonQuayLai"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="0dp"
                android:text="Quay lại"
                app:colorFont="@color/white"
                app:colorNormal="@color/balatro_yellow"
                app:fontSize="24sp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>